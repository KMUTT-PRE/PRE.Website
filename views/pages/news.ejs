<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/navbar', { title : 'news'} ) %>
    <link rel="stylesheet" href="/css/news.css" />
    <%- include('../partials/Responsive') %>
  </head>
  <body>
    <%- include('../partials/topbtn') %>
    <div class="navigation-tab">
      <a href="/">หน้าแรก</a>/
      <span>ข่าวสาร</span>
    </div>
    <div class="news-layout">
      <aside id="myBtnContainer" class="filter-buttons">
        <h2>หมวดหมู่ข่าว</h2>
        <h4>ประเภท</h4>
        <div class="btn-group">
          <button class="btn active" data-filter="all">ทั้งหมด</button>
          <button class="btn" data-filter="reward">รางวัล</button>
          <button class="btn" data-filter="scholarships">ทุนการศึกษา</button>
          <button class="btn" data-filter="hiring">รับสมัคร</button>
          <button class="btn" data-filter="club">ชมรมมด</button>
          <button class="btn" data-filter="event">กิจกรรม</button>
          <button class="btn" data-filter="news">ข่าวสาร</button>
        </div>
        <h4>สาขา</h4>
        <div class="btn-group">
          <button class="btn" data-filter="pre">PRE</button
          ><button class="btn" data-filter="mce">MCE</button
          ><button class="btn" data-filter="isee">ISEE</button
          ><button class="btn" data-filter="m-eng">ปริญญาโท</button
          ><button class="btn" data-filter="ph-d">ปริญญาเอก</button>
        </div>
      </aside>
      <div class="news-container">
  <h1>ข่าวและกิจกรรม</h1>

  <div id="carouselExampleDark" class="carousel carousel-dark slide" data-bs-ride="carousel">
    <div class="carousel-indicators">
      <% if (typeof carouselNews !== 'undefined' && carouselNews.length > 0) { %>
        <% carouselNews.forEach(function(file, index) { %>
          <button
            type="button"
            data-bs-target="#carouselExampleDark"
            data-bs-slide-to="<%= index %>"
            class="<%= index === 0 ? 'active' : '' %>"
            aria-current="<%= index === 0 ? 'true' : 'false' %>"
            aria-label="Slide <%= index + 1 %>"
          ></button>
        <% }); %>
      <% } %>
    </div>

    <div class="carousel-inner">
      <% if (typeof carouselNews !== 'undefined' && carouselNews.length > 0) { %>
        <% carouselNews.forEach(function(file, index) { %>
          <div class="carousel-item <%= index === 0 ? 'active' : '' %>" data-bs-interval="5000">
            <%- include('../news/2569/' + file) %>
          </div>
        <% }); %>
      <% } else { %>
        <div class="carousel-item active">
          <p class="text-center">ไม่มีข่าวไฮไลท์ในขณะนี้</p>
        </div>
      <% } %>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleDark" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleDark" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>
        <div class="card-container">
          <% if (newsFiles && newsFiles.length > 0) { %> <%
          newsFiles.forEach(function(file) { %> <%- include('../news/2569/' +
          file) %> <% }); %> <% } else { %>
          <p>ไม่มีข่าวสารในขณะนี้</p>
          <% } %>
        </div>
      </div>
    </div>
    <script src="../js/filternews.js"></script>
    <%- include('../partials/footer')-%>
  </body>
</html>
